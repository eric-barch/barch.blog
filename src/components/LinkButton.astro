---
export interface Props {
  href: string;
  className?: string;
  ariaLabel?: string;
  title?: string;
  disabled?: boolean;
}

const { href, className, ariaLabel, title, disabled = false } = Astro.props;
---

{
  disabled ? (
    <span
      class={`group ${className}`}
      aria-label={ariaLabel}
      title={title}
      aria-disabled={disabled}
    >
      <slot />
    </span>
  ) : (
    <a {href} class={`group ${className}`} aria-label={ariaLabel} title={title}>
      <slot />
    </a>
  )
}

<style>
  span {
    @apply inline-block;
  }
  a {
    @apply inline-block hover:text-skin-accent;
  }
</style>
